### Positive Control Linearity
positive_controls <- geneInfo$Name[geneInfo$Code.Class == "Positive"]
pos_counts <- counts_data[positive_controls,]
# Assume you know expected concentrations
expected_conc <- c(128, 32, 8, 2, 0.5, 0.125)  # or get from NanoString protocol
# Calculate linearity per sample
r_squared <- sapply(1:ncol(pos_counts), function(i) {
fit <- lm(log2(pos_counts[, i]) ~ log2(expected_conc))
summary(fit)$r.squared
})
# Flag bad samples
flagged_rsq <- colnames(pos_counts)[r_squared < 0.95]
print(flagged_rsq)
View(pos_counts)
pos_means <- colMeans(pos_counts)
geo_mean <- function(x) {
exp(mean(log(x[x > 0])))
}
geo_means_all <- apply(counts_data, 2, geo_mean)
geo_means_posC <- apply(counts_data, 2, geo_mean)
print(geo_means_all)
print(geo_means_posC)
geo_means_posC <- apply(pos_counts, 2, geo_mean)
print(geo_means_all)
print(geo_means_posC)
# Compare fold change: geo_means_posC/geo_means_all
fold_change <- geo_means_posC / geo_means_all
# Identify samples where fold difference > 3 or < 1/3
flagged_samples <- names(fold_change)[fold_change > 3 | fold_change < (1/3)]
# Show flagged samples
print(flagged_samples)
plot(fold_change, pch = 16, col = ifelse(fold_change > 3 | fold_change < 1/3, "red", "black"),
main = "Fold Change: Positive Control vs. Sample GM",
ylab = "Fold Change", xlab = "Sample Index")
abline(h = c(1/3, 3), col = "blue", lty = 2)
# Check for decreasing linearity of Positive Controls
# Initialize R² values
r_squared <- sapply(1:ncol(pos_counts), function(i) {
y <- as.numeric(pos_counts[, i])
x <- expected_conc
# log-transform both axes
model <- lm(log2(y + 1) ~ log2(x))
summary(model)$r.squared
})
# Set names
names(r_squared) <- colnames(pos_counts)
# Flag samples with R² < 0.95
bad_samples <- names(r_squared)[r_squared < 0.95]
